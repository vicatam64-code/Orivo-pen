<header class="sc-hdr">
  <div class="sc-wrap sc-hdr__inner">
    <a href="{{ routes.root_url }}" class="sc-logo">
      <span class="sc-logo__mark"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21c-4-3-7-6.5-7-11a7 7 0 0 1 14 0c0 4.5-3 8-7 11z"/><path d="M12 12c2-1 3-3 3-5"/></svg></span>
      <span>{{ section.settings.brand_text }}</span>
    </a>
    <nav class="sc-nav">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link' -%}
          <a href="{{ block.settings.url | default: routes.root_url }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
        {%- endif -%}
      {%- endfor -%}
      {%- if section.settings.show_cart -%}
      <a href="{{ routes.cart_url }}" class="sc-cart">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
        {{ section.settings.cart_label }}{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}
      </a>
      {%- endif -%}
    </nav>
  </div>
</header>
{% schema %}
{
  "name": "Site header",
  "settings": [
    { "type": "text", "id": "brand_text", "label": "Brand name", "default": "Orivo™" },
    { "type": "checkbox", "id": "show_cart", "label": "Show cart button", "default": true },
    { "type": "text", "id": "cart_label", "label": "Cart label", "default": "Cart" }
  ],
  "blocks": [
    { "type": "link", "name": "Nav link", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Contact" },
      { "type": "url", "id": "url", "label": "Link" }
    ] }
  ],
  "default": { "blocks": [ { "type": "link", "settings": { "label": "Contact", "url": "/pages/contact" } } ] }
}
{% endschema %}
