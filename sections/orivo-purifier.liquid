      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div class="ship-bar">
    <div class="ship-bar__msg" id="shipMsg">You're <b>R900</b> away from Free Shipping</div>
    <div class="ship-track"><div class="ship-fill" id="shipFill"></div></div>
    <div class="ship-bar__truck"><span>Cart</span><span>🚚 Free Shipping at R900</span></div>
  </div>

  <div class="cart__body" id="cartBody"></div>

  <div class="protect">
    <span style="font-size:18px;">🛡️</span>
    <div class="protect__txt">
      <div class="t">Add Shipping Protection — R49</div>
      <div class="d">Covers loss, theft or damage in transit.</div>
    </div>
    <button class="toggle" id="protectToggle" role="switch" aria-checked="false" aria-label="Toggle shipping protection"></button>
  </div>

  <div class="cart__foot">
    <div class="cart__total"><span class="lbl">Subtotal</span><span class="amt" id="cartTotal">R0</span></div>
    <button class="cart__checkout" id="cartCheckout">Checkout securely →</button>
  </div>
</aside>

{% raw %}
<script>
/* ============================================================
   ORIVO — Mullein Purifier · interactivity (real Shopify cart)
   ============================================================ */
(function () {
  "use strict";

  /* ---------- Shopify config (from #orivoConfig data-attrs) ---------- */
  var CFG = (function () {
    var el = document.getElementById("orivoConfig");
    var d = (el && el.dataset) || {};
    return {
      cartAdd: d.cartAdd || "/cart/add",
      cartUrl: d.cartUrl || "/cart",
      afterAdd: d.afterAdd || "drawer",
      variants: { t1: (d.vT1 || "").trim(), t2: (d.vT2 || "").trim(), t3: (d.vT3 || "").trim() },
      protection: (d.protection || "").trim(),
      saleHours: parseInt(d.saleHours, 10) || 5
    };
  })();

  /* ---------- Config / data (single source of truth) ---------- */
  var FREE_SHIP_THRESHOLD = 900;      // Rand
  var PROTECTION_FEE = 49;            // Rand
  var SALE_HOURS = CFG.saleHours || 5;   // countdown window (from settings)

  var TIERS = [
    { id: "t1", name: "Buy 1",            supply: "30 Day Supply",  qty: 1, price: 749,  compare: 999  },
    { id: "t2", name: "Buy 2, Get 1 FREE", supply: "90 Day Supply",  qty: 3, price: 1499, compare: 2997, badge: "Most Popular" },
    { id: "t3", name: "Buy 3, Get 2 FREE", supply: "150 Day Supply", qty: 5, price: 1999, compare: 4995, badge: "Best Value" }
  ];

  var state = {
    tierIndex: 1,            // default: Most Popular pre-selected
    protection: false,
    cart: []                 // {tier}
  };

  /* ---------- Money ---------- */
  function money(n) {
    return "R" + Math.round(n).toLocaleString("en-US");
  }

  var $ = function (s, r) { return (r || document).querySelector(s); };
  var $$ = function (s, r) { return Array.prototype.slice.call((r || document).querySelectorAll(s)); };

  /* ============================================================
     COUNTDOWN (persistent, datetime-based)
     ============================================================ */
  function getSaleEnd() {
    var key = "orivo_sale_end_5h";
    var stored = parseInt(localStorage.getItem(key), 10);
    var now = Date.now();
    if (!stored || isNaN(stored) || stored < now) {
      stored = now + SALE_HOURS * 3600 * 1000;
      try { localStorage.setItem(key, String(stored)); } catch (e) {}
    }
    return stored;
  }

  function initCountdowns() {
    var end = getSaleEnd();
    var groups = $$("[data-countdown]");
    function pad(n) { return (n < 10 ? "0" : "") + n; }
    var timer;
    function tick() {
      var diff = end - Date.now();
      if (diff <= 0) {
        groups.forEach(function (g) {
          var wrap = g.closest("[data-cd-wrap]") || g;
          var fb = wrap.querySelector("[data-cd-expired]");
          g.style.display = "none";
          if (fb) fb.style.display = "";
        });
        clearInterval(timer);
        return;
      }
      var d = Math.floor(diff / 86400000);
      var h = Math.floor((diff % 86400000) / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      groups.forEach(function (g) {
        var set = function (k, v) { var el = g.querySelector("[data-cd='" + k + "']"); if (el) el.textContent = pad(v); };
        set("d", d); set("h", h); set("m", m); set("s", s);
      });
    }
    tick();
    timer = setInterval(tick, 1000);
  }

  /* ============================================================
     LIVE VIEWER COUNT
     ============================================================ */
  function initViewers() {
    var els = $$("[data-viewers]");
    if (!els.length) return;
    var n = 26 + Math.floor(Math.random() * 12);
    function render() { els.forEach(function (el) { el.textContent = n; }); }
    render();
    setInterval(function () {
      n += Math.floor(Math.random() * 5) - 2;
      if (n < 18) n = 18; if (n > 44) n = 44;
      render();
    }, 4500);
  }

  /* ============================================================
     GALLERY
     ============================================================ */
  function initGallery() {
    var stage = $("#galStage");
    if (!stage) return;
    var slides = $$(".gal-slide", stage);
    var thumbs = $$(".gal-thumb");
    var i = 0;
    function go(n) {
      i = (n + slides.length) % slides.length;
      slides.forEach(function (s, k) { if (k === i) s.setAttribute("data-active", ""); else s.removeAttribute("data-active"); });
      thumbs.forEach(function (t, k) { if (k === i) t.setAttribute("data-active", ""); else t.removeAttribute("data-active"); });
    }
    $("#galPrev").addEventListener("click", function () { go(i - 1); });
    $("#galNext").addEventListener("click", function () { go(i + 1); });
    thumbs.forEach(function (t, k) { t.addEventListener("click", function () { go(k); }); });
    go(0);
  }

  /* ============================================================
     BUNDLE TIERS + PRICE SYNC
     ============================================================ */
  function selectedTier() { return TIERS[state.tierIndex]; }

  function selectedVariant() { var t = selectedTier(); return CFG.variants[t.id] || ""; }

  function syncOffer() {
    var t = selectedTier();
    var vInput = document.getElementById("orivoVariantInput");
    if (vInput) vInput.value = selectedVariant();
    $$(".tiers .tier").forEach(function (card, idx) {
      if (idx === state.tierIndex) card.setAttribute("data-selected", ""); else card.removeAttribute("data-selected");
      card.setAttribute("aria-checked", idx === state.tierIndex ? "true" : "false");
    });
    var atcPrice = $("#atcPrice");
    if (atcPrice) atcPrice.textContent = money(t.price);
    var st = $("#stickyTier"); if (st) st.textContent = t.name + " · " + t.supply;
    var sn = $("#stickyNow"); if (sn) sn.textContent = money(t.price);
    var sWas = $("#stickyWas");
    if (sWas) sWas.textContent = t.compare > t.price ? money(t.compare) : "";
  }

  function initTiers() {
    $$(".tiers .tier").forEach(function (card, idx) {
      card.setAttribute("role", "radio");
      card.setAttribute("tabindex", "0");
      function pick() { state.tierIndex = idx; syncOffer(); }
      card.addEventListener("click", pick);
      card.addEventListener("keydown", function (e) {
        if (e.key === "Enter" || e.key === " ") { e.preventDefault(); pick(); }
        if (e.key === "ArrowDown" || e.key === "ArrowRight") { e.preventDefault(); state.tierIndex = Math.min(TIERS.length - 1, idx + 1); syncOffer(); $$(".tiers .tier")[state.tierIndex].focus(); }
        if (e.key === "ArrowUp" || e.key === "ArrowLeft") { e.preventDefault(); state.tierIndex = Math.max(0, idx - 1); syncOffer(); $$(".tiers .tier")[state.tierIndex].focus(); }
      });
    });
    syncOffer();
  }

  /* ============================================================
     STICKY ADD-TO-CART (reveal after hero CTA scrolls away)
     ============================================================ */
  function initSticky() {
    var anchor = $("#atcAnchor");
    var bar = $("#stickyAtc");
    if (!anchor || !bar) return;
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) bar.removeAttribute("data-show");
        else if (e.boundingClientRect.top < 0) bar.setAttribute("data-show", "");
        else bar.removeAttribute("data-show");
      });
    }, { threshold: 0 });
    io.observe(anchor);
  }

  /* ============================================================
     ACCORDION (objection FAQ)
     ============================================================ */
  function initAccordion() {
    $$(".acc__item").forEach(function (item, idx) {
      var q = $(".acc__q", item);
      var a = $(".acc__a", item);
      q.setAttribute("aria-expanded", idx === 0 ? "true" : "false");
      if (idx === 0) { item.setAttribute("data-open", ""); a.style.maxHeight = a.scrollHeight + "px"; }
      q.addEventListener("click", function () {
        var open = item.hasAttribute("data-open");
        if (open) { item.removeAttribute("data-open"); a.style.maxHeight = 0; q.setAttribute("aria-expanded", "false"); }
        else { item.setAttribute("data-open", ""); a.style.maxHeight = a.scrollHeight + "px"; q.setAttribute("aria-expanded", "true"); }
      });
    });
    window.addEventListener("resize", function () {
      $$(".acc__item[data-open] .acc__a").forEach(function (a) { a.style.maxHeight = a.scrollHeight + "px"; });
    });
  }

  /* ============================================================
     CART DRAWER + FREE SHIPPING BAR  (real Shopify AJAX cart)
     ============================================================ */
  function fmtMoney(cents) { return "R" + Math.round((cents || 0) / 100).toLocaleString("en-US"); }

  function getCart() {
    return fetch(CFG.cartUrl + ".js", { headers: { "Accept": "application/json" }, credentials: "same-origin" })
      .then(function (r) { return r.json(); });
  }
  function addItems(items) {
    return fetch(CFG.cartAdd + ".js", {
      method: "POST", credentials: "same-origin",
      headers: { "Content-Type": "application/json", "Accept": "application/json" },
      body: JSON.stringify({ items: items })
    }).then(function (r) { if (!r.ok) { return r.json().then(function (e) { throw e; }); } return r.json(); });
  }
  function changeLine(key, qty) {
    return fetch("/cart/change.js", {
      method: "POST", credentials: "same-origin",
      headers: { "Content-Type": "application/json", "Accept": "application/json" },
      body: JSON.stringify({ id: key, quantity: qty })
    }).then(function (r) { return r.json(); });
  }

  function openCart() { var d = $("#cartDrawer"), o = $("#cartOverlay"); if (d) d.setAttribute("data-open", ""); if (o) o.setAttribute("data-open", ""); }
  function closeCart() { var d = $("#cartDrawer"), o = $("#cartOverlay"); if (d) d.removeAttribute("data-open"); if (o) o.removeAttribute("data-open"); }

  function renderShipBar(subCents) {
    var msg = $("#shipMsg"), fill = $("#shipFill");
    if (!fill) return;
    var threshold = FREE_SHIP_THRESHOLD * 100;
    fill.style.width = Math.min(100, Math.round((subCents / threshold) * 100)) + "%";
    if (!msg) return;
    if (subCents >= threshold) { msg.classList.add("done"); msg.innerHTML = "✓ You've unlocked <b>FREE Shipping</b>"; }
    else { msg.classList.remove("done"); msg.innerHTML = "You're <b>" + fmtMoney(threshold - subCents) + "</b> away from Free Shipping"; }
  }

  function protectionLine(cart) {
    if (!CFG.protection || !cart || !cart.items) return null;
    for (var i = 0; i < cart.items.length; i++) {
      var it = cart.items[i];
      if (String(it.variant_id) === CFG.protection || String(it.id) === CFG.protection) return it;
    }
    return null;
  }
  function syncProtectionToggle(cart) {
    var tg = $("#protectToggle");
    if (!tg) return;
    var row = tg.closest(".protect");
    if (!CFG.protection) { if (row) row.style.display = "none"; return; }
    var on = !!protectionLine(cart);
    if (on) tg.setAttribute("data-on", ""); else tg.removeAttribute("data-on");
    tg.setAttribute("aria-checked", on ? "true" : "false");
  }

  function renderCart(cart) {
    var body = $("#cartBody");
    var sub = (cart && cart.items_subtotal_price != null) ? cart.items_subtotal_price : (cart ? cart.total_price : 0);
    if (!cart || !cart.items || cart.items.length === 0) {
      if (body) body.innerHTML = '<div class="cart-empty">Your cart is empty.<br>Choose a bundle to get started.</div>';
      $$("[data-cart-count]").forEach(function (el) { el.textContent = "0"; el.style.display = "none"; });
      if ($("#cartTotal")) $("#cartTotal").textContent = fmtMoney(0);
      renderShipBar(0); syncProtectionToggle(null); return;
    }
    if (body) body.innerHTML = cart.items.map(function (l) {
      var was = (l.original_line_price > l.final_line_price) ? "<s>" + fmtMoney(l.original_line_price) + "</s>" : "";
      var meta = (l.variant_title && l.variant_title !== "Default Title") ? l.variant_title : ("Qty " + l.quantity);
      var img = l.image ? '<img src="' + l.image + '" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;">' : phSVG();
      return '<div class="cart-line">' +
        '<div class="cart-line__ph">' + img + '</div>' +
        '<div><div class="cart-line__nm">' + l.product_title + '</div>' +
        '<div class="cart-line__meta">' + meta + '</div></div>' +
        '<div class="cart-line__price">' + fmtMoney(l.final_line_price) + was + '</div>' +
        '</div>';
    }).join("");
    if ($("#cartTotal")) $("#cartTotal").textContent = fmtMoney(sub);
    $$("[data-cart-count]").forEach(function (el) { el.textContent = cart.item_count; el.style.display = cart.item_count ? "" : "none"; });
    renderShipBar(sub); syncProtectionToggle(cart);
  }

  function refreshCart() { return getCart().then(renderCart).catch(function () {}); }

  function showNotice(msg) { var n = $("#orivoNotice"); if (n) { n.hidden = false; n.textContent = msg; } }
  function clearNotice() { var n = $("#orivoNotice"); if (n) { n.hidden = true; n.textContent = ""; } }

  function addToCart(e) {
    if (e && e.preventDefault) e.preventDefault();
    clearNotice();
    var vid = selectedVariant();
    if (!vid) { showNotice("⚠ Add this bundle's Shopify variant ID in this section's settings to enable checkout."); return; }
    var btns = $$("[data-add-to-cart]");
    btns.forEach(function (b) { b.disabled = true; });
    addItems([{ id: vid, quantity: 1 }]).then(function () {
      if (CFG.afterAdd === "checkout") { window.location.href = "/checkout"; return null; }
      if (CFG.afterAdd === "cart") { window.location.href = CFG.cartUrl; return null; }
      return refreshCart().then(openCart);
    }).catch(function (err) {
      showNotice("Sorry — we couldn't add that to the cart. Check the variant ID is correct and in stock.");
      if (window.console) console.warn("Orivo add-to-cart failed:", err);
    }).then(function () { btns.forEach(function (b) { b.disabled = false; }); });
  }

  function initCart() {
    var form = document.getElementById("orivoBuyForm");
    if (form) form.addEventListener("submit", addToCart);

    var co = $("#cartOpen"); if (co) co.addEventListener("click", function () { refreshCart().then(openCart); });
    var cl = $("#cartClose"); if (cl) cl.addEventListener("click", closeCart);
    var ov = $("#cartOverlay"); if (ov) ov.addEventListener("click", closeCart);
    document.addEventListener("keydown", function (e) { if (e.key === "Escape") closeCart(); });

    var chk = $("#cartCheckout"); if (chk) chk.addEventListener("click", function () { window.location.href = "/checkout"; });

    var tg = $("#protectToggle");
    if (tg) tg.addEventListener("click", function () {
      if (!CFG.protection) return;
      getCart().then(function (cart) {
        var line = protectionLine(cart);
        if (line) { return changeLine(line.key, 0).then(renderCart); }
        return addItems([{ id: CFG.protection, quantity: 1 }]).then(refreshCart);
      });
    });

    refreshCart();
  }

  /* ============================================================
     SMOOTH ANCHOR to buy box
     ============================================================ */
  function initAnchors() {
    $$("[data-scroll-buybox]").forEach(function (a) {
      a.addEventListener("click", function (e) {
        e.preventDefault();
        var bb = $("#buybox");
        if (bb) window.scrollTo({ top: bb.getBoundingClientRect().top + window.pageYOffset - 80, behavior: "smooth" });
      });
    });
  }

  /* placeholder svg helper (used by cart lines) */
  function phSVG() {
    return '<div class="ph" style="padding:0"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="9.5" y="2.5" width="5" height="14" rx="2.5"/><path d="M12 16.5V21"/></svg></div>';
  }

  /* ---------- boot ---------- */
  document.addEventListener("DOMContentLoaded", function () {
    initCountdowns();
    initViewers();
    initGallery();
    initTiers();
    initSticky();
    initAccordion();
    initCart();
    initAnchors();
  });
})();
</script>
{% endraw %}

{% schema %}
{
  "name": "Orivo Purifier Page",
  "settings": [
    { "type": "header", "content": "Bundle variant IDs" },
    { "type": "paragraph", "content": "Paste the numeric Variant ID for each bundle. Find it in Shopify admin → Products → (open a variant) → the number at the end of the URL." },
    { "type": "text", "id": "variant_t1", "label": "Buy 1 — variant ID" },
    { "type": "text", "id": "variant_t2", "label": "Buy 2, Get 1 Free — variant ID" },
    { "type": "text", "id": "variant_t3", "label": "Buy 3, Get 2 Free — variant ID" },
    { "type": "text", "id": "variant_protection", "label": "Shipping Protection — variant ID (optional)" },
    { "type": "header", "content": "Checkout behaviour" },
    { "type": "select", "id": "after_add", "label": "After Add to Cart", "default": "drawer",
      "options": [
        { "value": "drawer", "label": "Open the slide-out cart" },
        { "value": "checkout", "label": "Go straight to checkout" },
        { "value": "cart", "label": "Go to the cart page" }
      ] },
    { "type": "header", "content": "Page chrome" },
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement bar", "default": true },
    { "type": "checkbox", "id": "show_header", "label": "Show Orivo's own header (off = use your theme header)", "default": true },
    { "type": "checkbox", "id": "show_footer", "label": "Show Orivo's own footer + disclaimer", "default": true },
    { "type": "header", "content": "Urgency elements" },
    { "type": "checkbox", "id": "show_countdown", "label": "Show countdown timer", "default": true },
    { "type": "range", "id": "sale_hours", "label": "Countdown length", "min": 1, "max": 48, "step": 1, "unit": "h", "default": 5 },
    { "type": "checkbox", "id": "show_viewers", "label": "Show live-viewers counter", "default": true },
    { "type": "checkbox", "id": "show_lowstock", "label": "Show low-stock warning", "default": true }
  ],
  "presets": [ { "name": "Orivo Purifier Page" } ]
}
{% endschema %}
