      <span>ends in</span>
      <span class="cd-unit"><b data-cd="h">00</b><span>HRS</span></span>
      <span class="cd-sep">:</span>
      <span class="cd-unit"><b data-cd="m">00</b><span>MIN</span></span>
      <span class="cd-sep">:</span>
      <span class="cd-unit"><b data-cd="s">00</b><span>SEC</span></span>
    </span>
    {%- endif -%}
    <span data-cd-expired style="display:none; font-weight:700;">SALE ENDING SOON · LIMITED STOCK</span>
  </div>
</div>
{%- endif -%}

<!-- ============================================================
     HEADER
     ============================================================ -->
{%- if section.settings.show_header -%}
<header class="hdr">
  <div class="wrap hdr__inner">
    <a href="{{ routes.root_url }}" class="logo" style="text-decoration:none;">
      <span class="logo__mark">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21c-4-3-7-6.5-7-11a7 7 0 0 1 14 0c0 4.5-3 8-7 11z"/><path d="M12 12c2-1 3-3 3-5"/></svg>
      </span>
      <span>Orivo<sup>™</sup></span>
    </a>
    <nav class="hdr__nav">
