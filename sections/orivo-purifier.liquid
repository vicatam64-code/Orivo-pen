{%- comment -%}
  ============================================================
  ORIVO — Mullein Purifier · Shopify section
  File: sections/orivo-purifier.liquid
  Set your real Variant IDs in: Theme editor → this section's
  settings (or in templates/page.orivo-purifier.json).
  ============================================================
{%- endcomment -%}
{%- liquid
  assign v_t1 = section.settings.variant_t1
  assign v_t2 = section.settings.variant_t2
  assign v_t3 = section.settings.variant_t3
  assign v_protection = section.settings.variant_protection
  assign after_add = section.settings.after_add | default: 'drawer'
  assign sale_hours = section.settings.sale_hours | default: 5
-%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ============================================================
   ORIVO — Mullein Purifier · Direct-Response Product Page
   Design system: Clean Clinical — white + soft greens
   Main selling point: helps you quit / cut down smoking.
   Structure: 1 Offer · 2 Problem · 3 Mechanism · 4 How-to ·
              5 Social proof · 6 Objection FAQ · 7 Close
   ============================================================ */

:root {
  /* Greens / brand */
  --green:        #2E7D5B;   /* primary accent / CTA */
  --green-700:    #246349;
  --green-800:    #1F5C42;
  --green-900:    #143C2C;
  --green-tint:   #EAF3EE;   /* soft fill */
  --green-tint-2: #F0F7F2;
  --green-line:   #CFE3D7;

  /* Ink + neutrals */
  --ink:        #16231D;
  --ink-soft:   #3B4842;
  --muted:      #65736C;
  --muted-2:    #8A968F;
  --line:       #E3EAE6;
  --line-2:     #EDF2EF;
  --bg:         #FFFFFF;
  --bg-soft:    #F6FAF8;
  --bg-soft-2:  #F1F6F3;

  /* Urgency (used sparingly) */
  --sale:       #C7402F;
  --sale-2:     #E0533D;
  --sale-tint:  #FBEBE8;

  /* Accents */
  --gold:       #E2A33B;   /* stars */
  --ink-btn:    #16231D;

  /* Type */
  --serif: "Space Grotesk", "Hanken Grotesk", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  --sans:  "Hanken Grotesk", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

  /* Radii + shadow */
  --r-sm: 8px;
  --r:    12px;
  --r-lg: 18px;
  --r-xl: 24px;
  --shadow-sm: 0 1px 2px rgba(20,40,30,.06), 0 1px 3px rgba(20,40,30,.05);
  --shadow:    0 4px 14px rgba(20,50,35,.08), 0 1px 3px rgba(20,50,35,.06);
  --shadow-lg: 0 18px 50px rgba(20,55,40,.16);

  --maxw: 1180px;
}

* { box-sizing: border-box; }

html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }

body {
  margin: 0;
  font-family: var(--sans);
  color: var(--ink);
  background: var(--bg);
  line-height: 1.5;
  font-size: 16px;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

img { display: block; max-width: 100%; }
button { font-family: inherit; cursor: pointer; }
a { color: inherit; }

h1, h2, h3, h4 { margin: 0; font-weight: 600; line-height: 1.12; letter-spacing: -0.01em; }
p { margin: 0; }

.wrap { width: 100%; max-width: var(--maxw); margin: 0 auto; padding: 0 20px; }
.eyebrow {
  font-size: 12.5px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase;
  color: var(--green); margin-bottom: 14px;
}
.section { padding: 78px 0; }
.section--tint { background: var(--bg-soft); }
.section--deep { background: var(--green-900); color: #EAF4ED; }

.serif { font-family: var(--serif); }

/* ============================================================
   ANNOUNCEMENT BAR
   ============================================================ */
.ann {
  background: var(--green-900);
  color: #EAF4ED;
  font-size: 13.5px;
  letter-spacing: .01em;
}
.ann__inner {
  display: flex; align-items: center; justify-content: center; gap: 14px;
  flex-wrap: wrap; padding: 9px 20px; text-align: center;
}
.ann__sale { font-weight: 700; letter-spacing: .04em; }
.ann__sale b { color: #FFD8A8; }
.ann__cd { display: flex; align-items: center; gap: 6px; font-variant-numeric: tabular-nums; }
.cd-unit {
  display: inline-flex; flex-direction: column; align-items: center; line-height: 1;
  background: rgba(255,255,255,.10); border-radius: 6px; padding: 4px 7px; min-width: 36px;
}
.cd-unit b { font-size: 15px; font-weight: 700; }
.cd-unit span { font-size: 8.5px; letter-spacing: .12em; opacity: .7; margin-top: 3px; }
.cd-sep { opacity: .5; font-weight: 700; }

/* ============================================================
   HEADER
   ============================================================ */
.hdr {
  position: sticky; top: 0; z-index: 40;
  background: rgba(255,255,255,.92);
  backdrop-filter: saturate(1.4) blur(10px);
  border-bottom: 1px solid var(--line);
}
.hdr__inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
.logo { display: flex; align-items: center; gap: 9px; font-weight: 700; font-size: 21px; letter-spacing: -.02em; }
.logo__mark {
  width: 30px; height: 30px; border-radius: 8px;
  background: var(--green); display: grid; place-items: center; color: #fff;
}
.logo sup { font-size: .5em; font-weight: 600; color: var(--muted); top: -.8em; }
.hdr__nav { display: flex; align-items: center; gap: 26px; font-size: 14.5px; color: var(--ink-soft); }
.hdr__nav a { text-decoration: none; }
.hdr__nav a:hover { color: var(--green); }
.cart-btn {
  position: relative; display: inline-flex; align-items: center; gap: 8px;
  background: var(--green-tint); border: 1px solid var(--green-line); color: var(--green-800);
  border-radius: 999px; padding: 8px 14px; font-weight: 600; font-size: 14px;
}
.cart-btn:hover { background: var(--green-tint-2); }
.cart-btn .pill {
  background: var(--green); color: #fff; border-radius: 999px; font-size: 11px; font-weight: 700;
  min-width: 18px; height: 18px; display: grid; place-items: center; padding: 0 5px;
}

/* ============================================================
   HERO
   ============================================================ */
.hero { padding: 34px 0 30px; }
.hero__grid { display: grid; grid-template-columns: minmax(0, 1.04fr) minmax(0, 1fr); gap: 48px; align-items: start; }

/* Gallery */
.gallery { position: sticky; top: 84px; }
.gal-stage {
  position: relative; aspect-ratio: 1/1; border-radius: var(--r-xl);
  overflow: hidden; border: 1px solid var(--line); background: var(--bg-soft);
}
.gal-slide { position: absolute; inset: 0; opacity: 0; transition: opacity .35s ease; }
.gal-slide[data-active] { opacity: 1; }
.gal-arrow {
  position: absolute; top: 50%; transform: translateY(-50%); z-index: 3;
  width: 42px; height: 42px; border-radius: 999px; border: 1px solid var(--line);
  background: rgba(255,255,255,.92); display: grid; place-items: center; color: var(--ink);
  box-shadow: var(--shadow-sm);
}
.gal-arrow:hover { background: #fff; color: var(--green); }
.gal-arrow--prev { left: 14px; }
.gal-arrow--next { right: 14px; }
.gal-badge {
  position: absolute; top: 16px; left: 16px; z-index: 3;
  background: var(--sale); color: #fff; font-weight: 700; font-size: 12px;
  letter-spacing: .04em; padding: 6px 11px; border-radius: 999px; text-transform: uppercase;
}
.gal-thumbs { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; margin-top: 12px; }
.gal-thumb {
  aspect-ratio: 1/1; border-radius: 12px; overflow: hidden; border: 2px solid var(--line);
  background: var(--bg-soft); padding: 0; position: relative;
}
.gal-thumb[data-active] { border-color: var(--green); }
.gal-thumb .ph { border: none; border-radius: 0; }

/* Designed placeholder graphic */
.ph {
  width: 100%; height: 100%; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 14px; text-align: center;
  border: 1px solid var(--green-line); border-radius: inherit; padding: 22px;
  background:
    radial-gradient(120% 90% at 50% 0%, var(--green-tint-2) 0%, var(--bg-soft) 60%);
}
.ph svg { color: var(--green); opacity: .82; }
.ph__label { font-size: 11.5px; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; color: var(--green-800); }
.ph__sub { font-size: 12.5px; color: var(--muted); max-width: 80%; }
.ph--alt { background: radial-gradient(120% 90% at 50% 0%, #FFF6E9 0%, var(--bg-soft) 62%); }
.ph--alt svg { color: var(--gold); }

/* ============================================================
   BUY BOX
   ============================================================ */
.buybox { display: flex; flex-direction: column; gap: 18px; }

.rating-row { display: flex; align-items: center; gap: 10px; font-size: 14px; }
.stars { display: inline-flex; gap: 1px; color: var(--gold); }
.rating-row .count { color: var(--muted); }
.rating-row .tag { color: var(--green-800); font-weight: 600; }
.rating-row .dot { color: var(--line); }

.buybox h1 { font-family: var(--serif); font-size: clamp(30px, 4.2vw, 42px); font-weight: 500; letter-spacing: -.018em; line-height: 1.06; }
.buybox h1 sup { font-size: .42em; font-weight: 600; color: var(--muted); top: -1.1em; }
.buybox .lede { font-size: 16px; color: var(--ink-soft); line-height: 1.55; margin-top: -4px; }
.buybox .lede b { color: var(--ink); }

.authenticity {
  display: flex; gap: 9px; align-items: flex-start; font-size: 13.5px; color: var(--ink-soft);
  background: var(--green-tint); border: 1px solid var(--green-line);
  padding: 10px 13px; border-radius: var(--r-sm);
}
.authenticity svg { flex: none; color: var(--green); margin-top: 1px; }
.authenticity b { color: var(--green-800); }

.benefits { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.benefit { display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--ink-soft); }
.benefit .emo {
  flex: none; width: 38px; height: 38px; border-radius: 10px; display: grid; place-items: center;
  background: var(--green-tint); font-size: 19px;
}

.scarcity {
  display: flex; align-items: center; gap: 9px; font-size: 13.5px; font-weight: 600; color: var(--sale);
}
.live-dot { width: 9px; height: 9px; border-radius: 999px; background: var(--sale-2); position: relative; flex: none; }
.live-dot::after {
  content: ""; position: absolute; inset: -5px; border-radius: 999px;
  border: 2px solid var(--sale-2); animation: ping 1.5s cubic-bezier(0,0,.2,1) infinite;
}
@keyframes ping { 0% { transform: scale(.7); opacity: .9; } 100% { transform: scale(1.8); opacity: 0; } }
.scarcity .n { font-variant-numeric: tabular-nums; }

.sale-label {
  display: inline-flex; align-self: flex-start; align-items: center; gap: 7px;
  font-size: 12px; font-weight: 800; letter-spacing: .1em; text-transform: uppercase;
  color: var(--sale); border-top: 1px dashed var(--green-line); border-bottom: 1px dashed var(--green-line);
  width: 100%; padding: 9px 0; justify-content: center;
}

/* Bundle tiers */
.tiers { display: flex; flex-direction: column; gap: 11px; }
.tier {
  position: relative; display: grid; grid-template-columns: 26px 1fr auto; gap: 14px; align-items: center;
  border: 1.5px solid var(--line); border-radius: var(--r); padding: 16px 16px; cursor: pointer;
  background: #fff; transition: border-color .15s, box-shadow .15s, background .15s;
}
.tier:hover { border-color: var(--green-line); }
.tier[data-selected] { border-color: var(--green); background: var(--green-tint-2); box-shadow: 0 0 0 3px rgba(46,125,91,.12); }
.tier[data-best] { margin-top: 12px; }
.tier__radio {
  width: 22px; height: 22px; border-radius: 999px; border: 2px solid var(--line-2);
  display: grid; place-items: center; background: #fff;
}
.tier[data-selected] .tier__radio { border-color: var(--green); }
.tier[data-selected] .tier__radio::after { content: ""; width: 11px; height: 11px; border-radius: 999px; background: var(--green); }
.tier__main .name { font-weight: 700; font-size: 16px; }
.tier__main .supply { font-size: 13px; color: var(--muted); margin-top: 2px; }
.tier__price { text-align: right; }
.tier__price .now { font-weight: 800; font-size: 19px; }
.tier__price .was { font-size: 13px; color: var(--muted-2); text-decoration: line-through; margin-left: 6px; }
.tier__price .per { display: block; font-size: 11.5px; color: var(--muted); margin-top: 2px; }
.tier__flag {
  position: absolute; top: -12px; left: 16px; background: var(--green); color: #fff;
  font-size: 11px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase;
  padding: 3px 10px; border-radius: 999px;
}
.tier[data-best] .tier__flag { background: var(--ink-btn); }
.tier__save {
  position: absolute; top: -11px; right: 14px; background: var(--sale-tint); color: var(--sale);
  font-size: 11px; font-weight: 800; padding: 3px 9px; border-radius: 999px; border: 1px solid #F2CFC9;
}

/* CTA */
.atc {
  width: 100%; border: none; border-radius: var(--r); background: var(--green); color: #fff;
  font-size: 17px; font-weight: 700; padding: 18px 20px; letter-spacing: .01em;
  box-shadow: 0 8px 22px rgba(46,125,91,.30); transition: transform .12s, background .15s, box-shadow .15s;
  display: flex; align-items: center; justify-content: center; gap: 10px;
}
.atc:hover { background: var(--green-700); transform: translateY(-1px); box-shadow: 0 12px 28px rgba(46,125,91,.36); }
.atc:active { transform: translateY(0); }
.atc .price { font-weight: 800; }
.atc__sub { text-align: center; font-size: 12.5px; color: var(--muted); margin-top: -4px; }

.reassure { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 8px 16px; font-size: 12.5px; color: var(--ink-soft); }
.reassure .item { display: inline-flex; align-items: center; gap: 6px; }
.reassure svg { color: var(--green); }
.reassure .dot { color: var(--line); }

.pay-badges { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; }
.pay-badge {
  height: 38px; min-width: 54px; padding: 0 13px; border-radius: 8px; border: 1px solid transparent;
  display: inline-flex; align-items: center; justify-content: center; gap: 5px;
  font-size: 13.5px; font-weight: 800; letter-spacing: .01em; line-height: 1;
}
.pay-badge svg { display: block; }
.pay-badge--visa   { background: #1A1F71; color: #fff; font-family: var(--serif); font-style: italic; font-weight: 700; letter-spacing: .06em; }
.pay-badge--mc     { background: #fff; border-color: var(--line); padding: 0 14px; }
.pay-badge--amex   { background: #1379C4; color: #fff; font-size: 12px; letter-spacing: .08em; }
.pay-badge--paypal { background: #fff; border-color: var(--line); font-style: italic; font-size: 13.5px; }
.pay-badge--paypal .pp1 { color: #253B80; }
.pay-badge--paypal .pp2 { color: #179BD7; }
.pay-badge--apple  { background: #000; color: #fff; font-weight: 600; }
.pay-badge--apple svg { margin-top: -1px; }
.pay-badge--gpay   { background: #fff; border-color: var(--line); color: #5F6368; font-weight: 700; }
.pay-badge--shop   { background: #5A31F4; color: #fff; font-style: italic; }
.pay-badge--klarna { background: #FFB3C7; color: #0A0B09; }
.mc-marks { display: inline-flex; align-items: center; }
.mc-marks i { width: 18px; height: 18px; border-radius: 50%; display: block; }
.mc-marks i:first-child { background: #EB001B; }
.mc-marks i:last-child { background: #F79E1B; margin-left: -8px; mix-blend-mode: multiply; }

.low-stock {
  display: flex; align-items: center; gap: 8px; justify-content: center;
  font-size: 12.5px; font-weight: 600; color: var(--sale);
  background: var(--sale-tint); border-radius: var(--r-sm); padding: 9px 12px;
}

/* ============================================================
   UGC bubble
   ============================================================ */
.ugc { margin-top: 18px; }
.ugc__card {
  display: grid; grid-template-columns: 78px 1fr; gap: 16px; align-items: center;
  background: var(--green-tint); border: 1px solid var(--green-line); border-radius: var(--r-lg); padding: 16px;
}
.ugc__ph { width: 78px; height: 78px; border-radius: 14px; overflow: hidden; }
.ugc__q { font-family: var(--serif); font-size: 17px; font-style: italic; color: var(--ink); line-height: 1.32; }
.ugc__name { font-size: 12.5px; color: var(--muted); margin-top: 7px; font-weight: 600; }
.ugc__name .vb { color: var(--green); }

/* ============================================================
   SECTION HEAD (shared)
   ============================================================ */
.section-head { max-width: 760px; margin: 0 auto 48px; text-align: center; }
.section-head h2 { font-family: var(--serif); font-size: clamp(28px, 4vw, 42px); font-weight: 500; letter-spacing: -.02em; }
.section-head p { color: var(--muted); font-size: 16px; margin-top: 14px; }

/* ============================================================
   §2 — PROBLEM / REFRAME
   ============================================================ */
.reframe { max-width: 880px; margin: 0 auto; text-align: center; }
.reframe h2 {
  font-family: var(--serif); font-size: clamp(34px, 5.4vw, 60px); font-weight: 500;
  line-height: 1.04; letter-spacing: -.028em;
}
.reframe h2 .muted { color: var(--muted-2); }
.reframe h2 em { font-style: italic; color: var(--green); }
.reframe__agitate { max-width: 660px; margin: 26px auto 0; display: flex; flex-direction: column; gap: 12px; }
.reframe__agitate p { font-size: clamp(16.5px, 1.7vw, 19px); color: var(--ink-soft); line-height: 1.55; }
.reframe__agitate p.kick { color: var(--ink); font-weight: 700; }

.vs { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; max-width: 920px; margin: 54px auto 0; align-items: stretch; }
.vs__card { border-radius: var(--r-lg); border: 1px solid var(--line); background: #fff; padding: 28px 26px; display: flex; flex-direction: column; }
.vs__card--bad { background: var(--bg-soft); }
.vs__card--good { border: 1.5px solid var(--green); background: var(--green-tint-2); box-shadow: 0 0 0 3px rgba(46,125,91,.10); }
.vs__tag { display: inline-flex; align-items: center; gap: 8px; font-size: 11.5px; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
.vs__card--bad .vs__tag { color: var(--sale); }
.vs__card--good .vs__tag { color: var(--green); }
.vs__title { font-family: var(--serif); font-size: 23px; font-weight: 500; margin: 13px 0 3px; }
.vs__sub { font-size: 13px; color: var(--muted); margin-bottom: 20px; }
.vs__list { display: flex; flex-direction: column; gap: 14px; }
.vs__row { display: grid; grid-template-columns: 22px 1fr; gap: 11px; align-items: start; font-size: 15px; line-height: 1.45; color: var(--ink-soft); }
.vs__row svg { margin-top: 2px; flex: none; }
.vs__card--bad .vs__row svg { color: var(--sale); }
.vs__card--good .vs__row svg { color: var(--green); }
.vs__card--good .vs__row { color: var(--ink); }

/* ============================================================
   §3 — MECHANISM / NAMED METHOD
   ============================================================ */
.method-name { text-align: center; max-width: 740px; margin: 0 auto 48px; }
.method-name .badge {
  display: inline-flex; align-items: center; gap: 9px; background: var(--green-900); color: #EAF4ED;
  border-radius: 999px; padding: 9px 18px; font-size: 12.5px; font-weight: 700; letter-spacing: .04em;
}
.method-name .badge svg { color: #8FD3AE; }
.method-name h2 { font-family: var(--serif); font-size: clamp(30px, 4.6vw, 50px); font-weight: 500; letter-spacing: -.022em; margin-top: 20px; }
.method-name h2 sup { font-size: .34em; font-weight: 600; color: var(--muted-2); top: -1.4em; }
.method-name p { margin: 18px auto 0; color: var(--ink-soft); font-size: 17px; line-height: 1.6; }

.herb-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.herb {
  background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg); overflow: hidden;
  box-shadow: var(--shadow-sm); transition: transform .18s, box-shadow .18s;
}
.herb:hover { transform: translateY(-3px); box-shadow: var(--shadow); }
.herb__img { aspect-ratio: 4/3; }
.herb__body { padding: 22px 22px 26px; }
.herb__step { font-size: 11.5px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; color: var(--muted-2); }
.herb__name { font-family: var(--serif); font-size: 23px; font-weight: 500; margin-top: 6px; }
.herb__tag { font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--green); margin: 6px 0 12px; }
.herb__body p { color: var(--ink-soft); font-size: 14.5px; line-height: 1.6; }

.method-delivery {
  max-width: 920px; margin: 28px auto 0; display: flex; align-items: center; gap: 16px;
  justify-content: center; flex-wrap: wrap; text-align: center;
  background: var(--green-tint); border: 1px dashed var(--green-line); border-radius: var(--r); padding: 18px 24px;
}
.method-delivery .ic { width: 42px; height: 42px; border-radius: 11px; background: #fff; display: grid; place-items: center; color: var(--green); flex: none; }
.method-delivery .t { font-weight: 800; color: var(--green-800); letter-spacing: .02em; }
.method-delivery .d { color: var(--ink-soft); font-size: 14.5px; max-width: 56ch; }

/* ============================================================
   §4 — HOW TO USE (curve + protocol + moments)
   ============================================================ */
.timeline { max-width: 1000px; margin: 0 auto; }
.timeline__svg { width: 100%; height: auto; display: block; overflow: visible; }
.timeline__points { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 20px; }
.tl-point { text-align: center; padding: 0 8px; }
.tl-point .when { font-size: 11.5px; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; color: var(--green); }
.tl-point .what { font-family: var(--serif); font-size: 18px; font-weight: 500; margin: 8px 0 6px; }
.tl-point .desc { font-size: 13.5px; color: var(--muted); line-height: 1.5; }
.timeline__note { text-align: center; font-size: 12.5px; color: var(--muted-2); margin-top: 26px; }

.protocol-head { text-align: center; margin: 70px auto 36px; }
.protocol-head .eyebrow { margin-bottom: 8px; }
.protocol-head h3 { font-family: var(--serif); font-size: clamp(24px, 3vw, 34px); font-weight: 500; letter-spacing: -.02em; }
.protocol { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; max-width: 940px; margin: 0 auto; }
.step { background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg); padding: 28px 26px; box-shadow: var(--shadow-sm); position: relative; }
.step__n { font-family: var(--serif); font-size: 14px; font-weight: 700; color: var(--green); letter-spacing: .14em; text-transform: uppercase; }
.step__ic { width: 54px; height: 54px; border-radius: 14px; background: var(--green-tint); display: grid; place-items: center; color: var(--green); margin: 14px 0 16px; }
.step h4 { font-size: 21px; font-weight: 700; }
.step p { color: var(--ink-soft); font-size: 14.5px; margin-top: 9px; line-height: 1.6; }

.moments-head { text-align: center; margin: 70px auto 34px; }
.moments-head h3 { font-family: var(--serif); font-size: clamp(22px, 2.6vw, 30px); font-weight: 500; letter-spacing: -.018em; }
.moments { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; max-width: 940px; margin: 0 auto; }
.moment { display: flex; align-items: center; gap: 14px; background: var(--bg-soft); border: 1px solid var(--line); border-radius: var(--r); padding: 16px 18px; }
.moment .ic { width: 42px; height: 42px; border-radius: 11px; background: #fff; border: 1px solid var(--line); display: grid; place-items: center; color: var(--green); flex: none; }
.moment .t { font-size: 14.5px; font-weight: 600; color: var(--ink); }

/* ============================================================
   §5 — SOCIAL PROOF (before/after + stats + testimonials)
   ============================================================ */
.rev-head { text-align: center; margin-bottom: 40px; max-width: 760px; margin-left: auto; margin-right: auto; }
.rev-head .stars { font-size: 22px; }
.rev-head h2 { font-family: var(--serif); font-size: clamp(28px, 4vw, 46px); font-weight: 500; margin-top: 12px; line-height: 1.06; letter-spacing: -.022em; }
.rev-head h2 em { font-style: italic; color: var(--green); }
.rev-head .rating-line { color: var(--muted); margin-top: 14px; font-size: 15px; }
.rev-head .rating-line b { color: var(--ink); }

.stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; max-width: 980px; margin: 0 auto 18px; }
.stat { text-align: center; padding: 26px 14px; background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg); }
.stat__n { font-family: var(--serif); font-size: 46px; font-weight: 500; color: var(--green); line-height: 1; letter-spacing: -.02em; }
.stat__t { font-size: 13.5px; color: var(--ink-soft); margin-top: 11px; line-height: 1.4; }
.stat-note { text-align: center; font-size: 12.5px; color: var(--muted-2); margin: 0 auto 46px; max-width: 64ch; }

.rev-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
.rev {
  background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg); padding: 24px;
  display: flex; flex-direction: column; gap: 14px; box-shadow: var(--shadow-sm);
}
.rev__top { display: flex; align-items: center; gap: 13px; }
.rev__ph { width: 50px; height: 50px; border-radius: 999px; overflow: hidden; flex: none; }
.rev__who .nm { font-weight: 700; font-size: 15px; }
.rev__who .meta { font-size: 12.5px; color: var(--muted); }
.rev__who .vb { color: var(--green); font-weight: 700; }
.rev__stars { color: var(--gold); font-size: 14px; }
.rev__body { font-size: 14.5px; color: var(--ink-soft); line-height: 1.6; }
.rev__body b { color: var(--ink); }

/* ============================================================
   §6 — OBJECTION FAQ (accordion)
   ============================================================ */
.acc { display: flex; flex-direction: column; gap: 0; max-width: 820px; margin: 0 auto; border-top: 1px solid var(--line); }
.acc__item { border-bottom: 1px solid var(--line); }
.acc__q {
  width: 100%; background: none; border: none; text-align: left; padding: 22px 4px;
  display: flex; align-items: center; justify-content: space-between; gap: 16px;
  font-size: 18px; font-weight: 600; color: var(--ink); font-family: var(--serif);
}
.acc__q .ico { flex: none; width: 26px; height: 26px; border-radius: 999px; border: 1px solid var(--line); display: grid; place-items: center; color: var(--green); transition: transform .2s, background .2s; }
.acc__item[data-open] .acc__q .ico { background: var(--green); color: #fff; transform: rotate(45deg); }
.acc__a { max-height: 0; overflow: hidden; transition: max-height .3s ease; }
.acc__a > div { padding: 0 4px 24px; color: var(--ink-soft); font-size: 15px; line-height: 1.62; max-width: 68ch; }
.acc__a b { color: var(--ink); }

/* ============================================================
   MARQUEE
   ============================================================ */
.marquee { background: var(--green); color: #EAF4ED; overflow: hidden; padding: 15px 0; }
.marquee__track { display: flex; gap: 0; width: max-content; animation: marq 30s linear infinite; }
.marquee__track:hover { animation-play-state: paused; }
.marquee__item { display: inline-flex; align-items: center; gap: 14px; padding: 0 26px; font-weight: 700; font-size: 14px; letter-spacing: .1em; text-transform: uppercase; white-space: nowrap; }
.marquee__item svg { opacity: .8; }
@keyframes marq { to { transform: translateX(-50%); } }

/* ============================================================
   §7 — CLOSE / GUARANTEE
   ============================================================ */
.guar { text-align: center; }
.guar__seal {
  width: 124px; height: 124px; border-radius: 999px; margin: 0 auto 26px;
  border: 3px solid var(--green); display: grid; place-items: center; color: var(--green);
  background: #fff; position: relative;
}
.guar__seal .big { font-family: var(--serif); font-weight: 600; font-size: 32px; line-height: .9; }
.guar__seal .sm { font-size: 10px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; margin-top: 4px; }
.guar h2 { font-family: var(--serif); font-size: clamp(28px, 4vw, 46px); font-weight: 500; max-width: 22ch; margin: 0 auto; line-height: 1.06; letter-spacing: -.022em; }
.guar h2 em { font-style: italic; color: var(--green); }
.guar p { color: var(--ink-soft); font-size: 16.5px; max-width: 62ch; margin: 20px auto 30px; line-height: 1.62; }
.guar__cta {
  display: inline-flex; align-items: center; gap: 9px; background: var(--green); color: #fff;
  border: none; border-radius: var(--r); padding: 17px 34px; font-size: 17px; font-weight: 700;
  box-shadow: 0 8px 22px rgba(46,125,91,.28); transition: transform .12s, background .15s, box-shadow .15s;
}
.guar__cta:hover { background: var(--green-700); transform: translateY(-1px); box-shadow: 0 12px 28px rgba(46,125,91,.34); }
.guar__price { font-size: 13.5px; color: var(--muted); margin-top: 16px; }
.guar__price s { color: var(--muted-2); }
.guar__price b { color: var(--ink); }
.guar__badges { display: flex; flex-wrap: wrap; justify-content: center; gap: 14px 28px; margin-top: 38px; }
.guar__badge { display: inline-flex; align-items: center; gap: 9px; font-size: 13.5px; font-weight: 600; color: var(--ink-soft); }
.guar__badge svg { color: var(--green); }

/* ============================================================
   FOOTER
   ============================================================ */
.ftr { background: var(--green-900); color: #BFD6C8; padding: 52px 0 40px; }
.ftr__top { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 24px; padding-bottom: 30px; border-bottom: 1px solid rgba(255,255,255,.1); }
.ftr .logo { color: #fff; }
.ftr .logo__mark { background: #fff; color: var(--green-900); }
.ftr__links { display: flex; gap: 30px; font-size: 14px; }
.ftr__links a { text-decoration: none; }
.ftr__links a:hover { color: #fff; }
.ftr__disc { font-size: 12px; line-height: 1.7; margin-top: 26px; max-width: 92ch; color: #93B3A1; }
.ftr__copy { font-size: 12.5px; margin-top: 20px; color: #7FA290; }

/* ============================================================
   STICKY ADD-TO-CART
   ============================================================ */
.sticky-atc {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 50;
  padding: 0 0 18px; pointer-events: none;
  transform: translateY(140%); transition: transform .3s ease;
}
.sticky-atc[data-show] { transform: translateY(0); }
.sticky-atc__inner {
  pointer-events: auto;
  display: flex; align-items: center; gap: 18px;
  background: #fff; border: 1px solid var(--line); border-radius: 26px;
  box-shadow: 0 18px 50px rgba(20,55,40,.18), 0 2px 8px rgba(20,55,40,.08);
  padding: 14px 16px 14px 18px; max-width: var(--maxw); margin: 0 auto;
}
.sticky-atc__info { display: flex; align-items: center; gap: 18px; min-width: 0; flex: 1; }
.sticky-atc__ph { width: 66px; height: 66px; border-radius: 16px; overflow: hidden; flex: none; background: var(--green-tint); }
.sticky-atc__txt { min-width: 0; }
.sticky-atc__txt .eyebrow2 { display: flex; align-items: center; gap: 8px; font-size: 11.5px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--green); }
.sticky-atc__txt .eyebrow2 .dot { width: 9px; height: 9px; border-radius: 999px; background: #79C99A; flex: none; }
.sticky-atc__txt .nm { font-weight: 800; font-size: 21px; letter-spacing: -.015em; color: var(--ink); margin-top: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.sticky-atc__txt .sub { font-size: 14.5px; color: var(--muted); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.sticky-atc__txt .price-line { display: flex; align-items: baseline; gap: 10px; margin-top: 6px; }
.sticky-atc__txt .price-line .now { font-weight: 800; font-size: 21px; color: var(--ink); }
.sticky-atc__txt .price-line .was { font-size: 15px; color: var(--muted-2); text-decoration: line-through; }
.sticky-atc__btn {
  flex: none; width: auto; border: none; border-radius: 999px;
  background: var(--green-900); color: #fff;
  font-size: 15px; font-weight: 800; letter-spacing: .07em; text-transform: uppercase;
  padding: 20px 44px; box-shadow: none; transition: background .15s, transform .12s;
  display: inline-flex; align-items: center; gap: 10px;
}
.sticky-atc__btn:hover { background: var(--green-800); transform: translateY(-1px); }
.sticky-atc__btn:active { transform: translateY(0); }

/* ============================================================
   CART DRAWER
   ============================================================ */
.cart-overlay {
  position: fixed; inset: 0; z-index: 60; background: rgba(16,35,28,.42);
  opacity: 0; pointer-events: none; transition: opacity .25s;
}
.cart-overlay[data-open] { opacity: 1; pointer-events: auto; }
.cart {
  position: fixed; top: 0; right: 0; bottom: 0; width: min(420px, 92vw); z-index: 61;
  background: #fff; display: flex; flex-direction: column;
  transform: translateX(100%); transition: transform .3s ease; box-shadow: var(--shadow-lg);
}
.cart[data-open] { transform: translateX(0); }
.cart__head { display: flex; align-items: center; justify-content: space-between; padding: 18px 20px; border-bottom: 1px solid var(--line); }
.cart__head h3 { font-size: 17px; }
.cart__close { background: none; border: none; color: var(--muted); width: 34px; height: 34px; border-radius: 999px; display: grid; place-items: center; }
.cart__close:hover { background: var(--bg-soft); color: var(--ink); }

.ship-bar { padding: 16px 20px; background: var(--bg-soft); border-bottom: 1px solid var(--line); }
.ship-bar__msg { font-size: 13.5px; font-weight: 600; margin-bottom: 9px; display: flex; align-items: center; gap: 7px; }
.ship-bar__msg b { color: var(--green); }
.ship-bar__msg.done { color: var(--green); }
.ship-track { height: 8px; border-radius: 999px; background: var(--green-line); overflow: hidden; }
.ship-fill { height: 100%; background: var(--green); border-radius: 999px; transition: width .35s ease; width: 0%; }
.ship-bar__truck { font-size: 11.5px; color: var(--muted); margin-top: 8px; display: flex; justify-content: space-between; }

.cart__body { flex: 1; overflow-y: auto; padding: 16px 20px; }
.cart-line { display: grid; grid-template-columns: 62px 1fr auto; gap: 13px; align-items: center; padding: 14px 0; border-bottom: 1px solid var(--line-2); }
.cart-line__ph { width: 62px; height: 62px; border-radius: 10px; overflow: hidden; }
.cart-line__nm { font-weight: 600; font-size: 14px; }
.cart-line__meta { font-size: 12.5px; color: var(--muted); margin-top: 2px; }
.cart-line__price { font-weight: 700; font-size: 15px; }
.cart-line__price s { display: block; font-size: 12px; color: var(--muted-2); font-weight: 400; }
.cart-empty { text-align: center; color: var(--muted); padding: 40px 0; font-size: 14px; }

.protect {
  display: flex; align-items: center; gap: 12px; padding: 14px 20px; border-top: 1px solid var(--line);
  background: var(--bg-soft); font-size: 13px;
}
.protect__txt { flex: 1; }
.protect__txt .t { font-weight: 700; }
.protect__txt .d { color: var(--muted); font-size: 12px; }
.toggle { width: 44px; height: 26px; border-radius: 999px; background: var(--line); border: none; position: relative; flex: none; transition: background .2s; }
.toggle::after { content: ""; position: absolute; top: 3px; left: 3px; width: 20px; height: 20px; border-radius: 999px; background: #fff; box-shadow: var(--shadow-sm); transition: transform .2s; }
.toggle[data-on] { background: var(--green); }
.toggle[data-on]::after { transform: translateX(18px); }

.cart__foot { padding: 16px 20px 20px; border-top: 1px solid var(--line); }
.cart__total { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 14px; }
.cart__total .lbl { font-size: 14px; color: var(--muted); }
.cart__total .amt { font-weight: 800; font-size: 22px; }
.cart__checkout { width: 100%; border: none; border-radius: var(--r); background: var(--green); color: #fff; font-size: 16px; font-weight: 700; padding: 16px; }
.cart__checkout:hover { background: var(--green-700); }

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 920px) {
  .hero__grid { grid-template-columns: 1fr; gap: 28px; }
  .gallery { position: static; }
  .herb-grid { grid-template-columns: 1fr; }
  .vs { grid-template-columns: 1fr; gap: 16px; }
  .protocol { grid-template-columns: 1fr; }
  .moments { grid-template-columns: 1fr 1fr; }
  .timeline__points { grid-template-columns: 1fr 1fr; gap: 22px 16px; }
  .stat-grid { grid-template-columns: 1fr 1fr; }
  .rev-grid { grid-template-columns: 1fr; }
  .hdr__nav .nav-links { display: none; }
}
@media (max-width: 560px) {
  .section { padding: 54px 0; }
  .benefits { grid-template-columns: 1fr; }
  .moments { grid-template-columns: 1fr; }
  .stat-grid { grid-template-columns: 1fr 1fr; }
  .ftr__top { flex-direction: column; }
  .sticky-atc { padding: 0 0 12px; }
  .sticky-atc__inner { gap: 12px; padding: 12px; border-radius: 20px; }
  .sticky-atc__txt .sub, .sticky-atc__txt .price-line .was { display: none; }
  .sticky-atc__info .sticky-atc__ph { display: none; }
  .sticky-atc__txt .nm { font-size: 17px; margin-top: 2px; }
  .sticky-atc__btn { padding: 15px 22px; font-size: 13.5px; }
  .ann__inner { gap: 8px; }
  .stat__n { font-size: 38px; }
}
@media (prefers-reduced-motion: reduce) {
  .marquee__track { animation: none; }
  .live-dot::after { animation: none; }
  html { scroll-behavior: auto; }
  * { transition-duration: .01ms !important; }
}
</style>

<style id="orivo-shopify">
  /* Shopify integration polish + mobile hardening */
  @media (min-width: 921px){ .sticky-atc{ display:none !important; } }
  .sticky-atc{ padding-bottom: calc(18px + env(safe-area-inset-bottom, 0px)); }
  @media (max-width:560px){ .sticky-atc{ padding-bottom: calc(12px + env(safe-area-inset-bottom, 0px)); } }
  #orivoBuyForm{ display:flex; flex-direction:column; gap:18px; margin:0; }
  .atc__warn{ color: var(--sale); font-weight:600; }
  [data-add-to-cart][disabled]{ cursor: wait; opacity:.7; }
  @media (max-width:560px){
    .hdr__nav{ gap:14px; }
    .tier{ padding:18px 16px; }
    .gal-arrow{ width:40px; height:40px; }
  }
</style>

<div id="orivoConfig"
     data-cart-add="{{ routes.cart_add_url }}"
     data-cart-url="{{ routes.cart_url }}"
     data-after-add="{{ after_add }}"
     data-v-t1="{{ v_t1 }}"
     data-v-t2="{{ v_t2 }}"
     data-v-t3="{{ v_t3 }}"
     data-protection="{{ v_protection }}"
     data-sale-hours="{{ sale_hours }}"
     hidden></div>

<!-- ============================================================
     ANNOUNCEMENT BAR
     ============================================================ -->
{%- if section.settings.show_announcement -%}
<div class="ann" data-cd-wrap>
  <div class="ann__inner">
    <span class="ann__sale">QUIT-FOR-GOOD SALE — UP TO <b>60% OFF</b> · WHILE STOCKS LAST</span>
    {%- if section.settings.show_countdown -%}
