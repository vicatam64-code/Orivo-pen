{%- comment -%} Generic page template — with a redesigned contact page on /pages/contact {%- endcomment -%}

{%- if page.handle == 'contact' or page.template_suffix == 'contact' -%}
  <style>
    .cx-wrap{max-width:1120px;margin:0 auto;padding:0 22px;}
    .cx-hero{background:linear-gradient(180deg,#F0F7F2 0%,#FFFFFF 100%);border-bottom:1px solid #E3EAE6;padding:64px 0 56px;text-align:center;}
    .cx-eyebrow{display:inline-flex;align-items:center;gap:7px;background:#EAF3EE;color:#1F5C42;border:1px solid #CFE3D7;border-radius:999px;padding:6px 14px;font-size:13px;font-weight:600;margin-bottom:18px;}
    .cx-hero h1{font-family:'Space Grotesk',sans-serif;font-size:46px;line-height:1.08;margin:0 0 14px;color:#16231D;letter-spacing:-.5px;}
    .cx-hero p{font-size:18px;line-height:1.65;color:#3B4842;margin:0 auto;max-width:560px;}
    .cx-grid{display:grid;grid-template-columns:1fr 1.25fr;gap:32px;align-items:start;margin:-36px auto 72px;}
    .cx-card{background:#fff;border:1px solid #E3EAE6;border-radius:18px;box-shadow:0 10px 30px rgba(20,60,44,.06);}
    .cx-aside{display:flex;flex-direction:column;gap:14px;}
    .cx-info{padding:22px 22px;display:flex;gap:14px;align-items:flex-start;}
    .cx-info__ic{flex:none;width:42px;height:42px;border-radius:11px;background:#EAF3EE;color:#2E7D5B;display:flex;align-items:center;justify-content:center;}
    .cx-info h4{margin:2px 0 4px;font-family:'Space Grotesk',sans-serif;font-size:16px;color:#16231D;}
    .cx-info p,.cx-info a{margin:0;font-size:14.5px;line-height:1.55;color:#65736C;text-decoration:none;}
    .cx-info a:hover{color:#2E7D5B;}
    .cx-quick{padding:20px 22px;}
    .cx-quick h4{margin:0 0 12px;font-family:'Space Grotesk',sans-serif;font-size:15px;color:#16231D;}
    .cx-quick a{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-top:1px solid #EDF2EF;color:#3B4842;text-decoration:none;font-size:14.5px;font-weight:500;}
    .cx-quick a:first-of-type{border-top:none;}
    .cx-quick a:hover{color:#2E7D5B;}
    .cx-form{padding:34px 34px 36px;}
    .cx-form h2{font-family:'Space Grotesk',sans-serif;font-size:24px;margin:0 0 6px;color:#16231D;}
    .cx-form .cx-sub{font-size:15px;color:#65736C;margin:0 0 22px;}
    .cx-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
    .cx-field{display:block;margin-top:16px;}
    .cx-field span{display:block;font-weight:600;font-size:13.5px;color:#16231D;margin-bottom:7px;}
    .cx-field input,.cx-field textarea{width:100%;box-sizing:border-box;padding:13px 14px;border:1px solid #E3EAE6;border-radius:11px;font:inherit;font-size:15.5px;color:#16231D;background:#F9FBFA;transition:border-color .15s,background .15s;}
    .cx-field input:focus,.cx-field textarea:focus{outline:none;border-color:#2E7D5B;background:#fff;box-shadow:0 0 0 3px rgba(46,125,91,.12);}
    .cx-field textarea{resize:vertical;min-height:130px;}
    .cx-btn{margin-top:24px;width:100%;background:#2E7D5B;color:#fff;border:none;border-radius:999px;padding:15px 30px;font-weight:700;font-size:15.5px;cursor:pointer;transition:background .15s;}
    .cx-btn:hover{background:#246349;}
    .cx-note{font-size:12.5px;color:#8A968F;margin:14px 0 0;text-align:center;}
    .cx-alert{border-radius:12px;padding:15px 18px;font-size:14.5px;margin-bottom:18px;}
    .cx-alert--ok{background:#EAF3EE;border:1px solid #CFE3D7;color:#1F5C42;}
    .cx-alert--err{background:#FBEBE8;border:1px solid #F2C7BF;color:#C7402F;}
    @media(max-width:860px){
      .cx-hero{padding:48px 0 44px;}.cx-hero h1{font-size:34px;}
      .cx-grid{grid-template-columns:1fr;gap:20px;margin:-28px auto 56px;}
      .cx-row{grid-template-columns:1fr;}.cx-form{padding:26px 22px 28px;}
    }
  </style>

  <section class="cx-hero">
    <div class="cx-wrap">
      <span class="cx-eyebrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> We usually reply within 24 hours</span>
      <h1>{{ page.title | default: 'Get in touch' }}</h1>
      <p>{% if page.content != blank %}{{ page.content | strip_html | truncatewords: 36 }}{% else %}Questions about your order or the Orivo&trade; Mullein Purifier? Our team is here to help — send us a message and we&rsquo;ll get right back to you.{% endif %}</p>
    </div>
  </section>

  <div class="cx-wrap">
    <div class="cx-grid">
      <aside class="cx-aside">
        <div class="cx-card cx-info">
          <span class="cx-info__ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg></span>
          <div><h4>Email us</h4><a href="mailto:{{ shop.email | default: 'support@orivo.co.za' }}">{{ shop.email | default: 'support@orivo.co.za' }}</a></div>
        </div>
        <div class="cx-card cx-info">
          <span class="cx-info__ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
          <div><h4>Response time</h4><p>Within 24 hours, Mon&ndash;Fri</p></div>
        </div>
        <div class="cx-card cx-quick">
          <h4>Quick help</h4>
          <a href="/pages/track-order"><span>Track your order</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></a>
          <a href="/pages/faqs"><span>FAQs</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></a>
          <a href="/pages/return-policy"><span>Returns &amp; refunds</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></a>
          <a href="/pages/shipping-policy"><span>Shipping info</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></a>
        </div>
      </aside>

      <div class="cx-card cx-form">
        <h2>Send us a message</h2>
        <p class="cx-sub">Fill in the form below and we&rsquo;ll get back to you by email.</p>
        {%- form 'contact' -%}
          {%- if form.posted_successfully? -%}
            <div class="cx-alert cx-alert--ok">Thanks &mdash; your message has been sent. We&rsquo;ll be in touch shortly.</div>
          {%- endif -%}
          {%- if form.errors -%}
            <div class="cx-alert cx-alert--err">{{ form.errors | default_errors }}</div>
          {%- endif -%}
          <div class="cx-row">
            <label class="cx-field"><span>Name</span><input type="text" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="Your name" required></label>
            <label class="cx-field"><span>Email</span><input type="email" name="contact[email]" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" placeholder="you@email.com" required></label>
          </div>
          <label class="cx-field"><span>Phone <em style="color:#8A968F;font-style:normal;font-weight:500;">(optional)</em></span><input type="tel" name="contact[phone]" value="{{ form.phone }}" placeholder="Order number or phone"></label>
          <label class="cx-field"><span>Message</span><textarea name="contact[body]" placeholder="How can we help?" required>{{ form.body }}</textarea></label>
          <button type="submit" class="cx-btn">Send message</button>
          <p class="cx-note">By sending, you agree to be contacted about your enquiry.</p>
        {%- endform -%}
      </div>
    </div>
  </div>

{%- else -%}

  <div class="page-width" style="max-width:780px;margin:0 auto;padding:56px 22px;font-family:'Hanken Grotesk',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#16231D;">
    <h1 style="font-family:'Space Grotesk',sans-serif;font-size:38px;line-height:1.1;margin:0 0 22px;">{{ page.title }}</h1>
    <div class="rte" style="font-size:17px;line-height:1.7;color:#3B4842;">{{ page.content }}</div>
  </div>

{%- endif -%}
