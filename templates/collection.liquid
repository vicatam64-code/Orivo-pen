{%- comment -%} Minimal collection template {%- endcomment -%}
<div style="max-width:1080px;margin:0 auto;padding:56px 22px;font-family:'Hanken Grotesk',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#16231D;">
  <h1 style="font-family:'Space Grotesk',sans-serif;font-size:34px;margin:0 0 28px;">{{ collection.title }}</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:26px;">
    {%- for product in collection.products -%}
      <a href="{{ product.url }}" style="text-decoration:none;color:inherit;">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.featured_image.alt | escape }}" style="width:100%;height:auto;border-radius:12px;">
        {%- endif -%}
        <p style="margin:12px 0 4px;font-weight:600;">{{ product.title }}</p>
        <p style="margin:0;color:#3B4842;">{{ product.price | money }}</p>
      </a>
    {%- else -%}
      <p>No products found.</p>
    {%- endfor -%}
  </div>
</div>
