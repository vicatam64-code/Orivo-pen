{%- comment -%} Article template {%- endcomment -%}
<div style="max-width:720px;margin:0 auto;padding:56px 22px;font-family:'Hanken Grotesk',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#16231D;">
  <h1 style="font-family:'Space Grotesk',sans-serif;font-size:36px;line-height:1.12;margin:0 0 10px;">{{ article.title }}</h1>
  <p style="color:#65736C;margin:0 0 28px;">{{ article.published_at | date: "%B %e, %Y" }}</p>
  <div class="rte" style="font-size:17px;line-height:1.75;color:#3B4842;">{{ article.content }}</div>
</div>
