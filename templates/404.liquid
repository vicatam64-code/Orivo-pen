{%- comment -%} 404 template {%- endcomment -%}
<div style="max-width:640px;margin:0 auto;padding:96px 22px;text-align:center;font-family:'Hanken Grotesk',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#16231D;">
  <h1 style="font-family:'Space Grotesk',sans-serif;font-size:46px;margin:0 0 14px;">{{ 'general.404.title' | t }}</h1>
  <p style="color:#65736C;font-size:18px;margin:0 0 26px;">{{ 'general.404.subtext' | t }}</p>
  <a href="{{ routes.root_url }}" style="background:#2E7D5B;color:#fff;border-radius:999px;padding:14px 28px;font-weight:700;text-decoration:none;">{{ 'general.404.link' | t }}</a>
</div>
