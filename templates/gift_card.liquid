{%- comment -%} Gift card template {%- endcomment -%}
<div style="max-width:520px;margin:0 auto;padding:64px 22px;text-align:center;font-family:'Hanken Grotesk',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#16231D;">
  <h1 style="font-family:'Space Grotesk',sans-serif;font-size:32px;margin:0 0 18px;">{{ shop.name }} Gift Card</h1>
  <p style="font-size:30px;font-weight:700;margin:0 0 10px;">{{ gift_card.balance | money }}</p>
  <p style="color:#65736C;">Gift card code:</p>
  <p style="font-family:monospace;font-size:20px;letter-spacing:2px;">{{ gift_card.code | format_code }}</p>
</div>
