{%- comment -%} Brand fonts + shared header/footer styles {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{--sc-green:#2E7D5B;--sc-ink:#16231D;--sc-ink-soft:#3B4842;--sc-muted:#65736C;--sc-line:#E3EAE6;--sc-bg-soft:#F6FAF8;
    --sc-serif:"Space Grotesk","Hanken Grotesk",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    --sc-sans:"Hanken Grotesk",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;}
  body{margin:0;font-family:var(--sc-sans);color:var(--sc-ink);background:#fff;}
  .sc-wrap{max-width:1180px;margin:0 auto;padding:0 22px;}
  .sc-hdr{border-bottom:1px solid var(--sc-line);background:#fff;position:sticky;top:0;z-index:50;}
  .sc-hdr__inner{display:flex;align-items:center;justify-content:space-between;height:68px;}
  .sc-logo{display:inline-flex;align-items:center;gap:9px;text-decoration:none;color:var(--sc-ink);font-family:var(--sc-serif);font-weight:700;font-size:19px;}
  .sc-logo__mark{display:inline-flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:8px;background:var(--sc-green);color:#fff;}
  .sc-nav{display:flex;align-items:center;gap:26px;}
  .sc-nav a{text-decoration:none;color:var(--sc-ink-soft);font-weight:600;font-size:15px;}
  .sc-nav a:hover{color:var(--sc-green);}
  .sc-cart{display:inline-flex;align-items:center;gap:7px;border:1px solid var(--sc-line);background:#fff;color:var(--sc-ink);border-radius:999px;padding:9px 16px;font-weight:600;font-size:14px;text-decoration:none;}
  .sc-cart:hover{border-color:var(--sc-green);color:var(--sc-green);}
  .sc-ftr{border-top:1px solid var(--sc-line);background:var(--sc-bg-soft);margin-top:64px;padding:40px 0 48px;}
  .sc-ftr__top{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:22px;}
  .sc-ftr__links{display:flex;gap:24px;flex-wrap:wrap;}
  .sc-ftr__links a{text-decoration:none;color:var(--sc-ink-soft);font-weight:600;font-size:15px;}
  .sc-ftr__links a:hover{color:var(--sc-green);}
  .sc-ftr__disc{font-size:12.5px;line-height:1.7;color:var(--sc-muted);margin:0 0 14px;}
  .sc-ftr__copy{font-size:13px;color:var(--sc-muted);margin:0;}
  @media(max-width:600px){.sc-hdr__inner{height:60px;}.sc-nav{gap:14px;}}
</style>
